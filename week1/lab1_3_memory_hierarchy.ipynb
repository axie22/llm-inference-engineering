   "source": [
    "## 1.1 Measuring Memory Access Times"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def measure_memory_access_times():\n",
    "    \"\"\"Measure access times for different memory hierarchy levels.\"\"\"\n",
    "    \n",
    "    if not torch.cuda.is_available():\n",
    "        print(\"CUDA not available - skipping memory experiments\")\n",
    "        return\n",
    "    \n",
    "    print(\"Memory Access Time Measurements\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    # 1. Register access (through arithmetic)\n",
    "    print(\"\\n1. Register Access (arithmetic operations):\")\n",
    "    \n",
    "    # Use tensor in registers (small computation)\n",
    "    a = torch.tensor([1.0], device='cuda')\n",
    "    b = torch.tensor([2.0], device='cuda')\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    iterations = 1000000\n",
    "    for i in range(iterations):\n",
    "        a = a + b  # Register operation\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    elapsed = time.time() - start\n",
    "    \n",
    "    ops_per_sec = iterations / elapsed\n",
    "    ns_per_op = elapsed / iterations * 1e9\n",
    "    \n",
    "    results.append({\n",
    "        'memory_type': 'Registers (through arithmetic)',\n",
    "        'ns_per_access': ns_per_op,\n",
    "        'accesses_per_sec': ops_per_sec\n",
    "    })\n",
    "    \n",
    "    print(f\"  Operations/sec: {ops_per_sec:.0f}\")\n",
    "    print(f\"  Time per operation: {ns_per_op:.1f} ns\")\n",
    "    \n",
    "    # 2. Shared memory access simulation\n",
    "    print(\"\\n2. Shared Memory Access (bank conflicts test):\")\n",
    "    \n",
    "    # Create array that fits in shared memory (64KB typical)\n",
    "    size = 16384  # 16K floats = 64KB\n",
    "    data = torch.randn(size, device='cuda')\n",
    "    \n",
    "    # Sequential access (no bank conflicts)\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    acc = torch.tensor(0.0, device='cuda')\n",
    "    for i in range(0, size, 1):  # Stride 1\n",
    "        acc += data[i]\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    sequential_time = time.time() - start\n",
    "    \n",
    "    # Strided access (bank conflicts)\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    acc = torch.tensor(0.0, device='cuda')\n",
    "    for i in range(0, size, 32):  # Stride 32 (typical bank count)\n",
    "        acc += data[i]\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    strided_time = time.time() - start\n",
    "    \n",
    "    bank_conflict_penalty = strided_time / sequential_time\n",
    "    \n",
    "    results.append({\n",
    "        'memory_type': 'Shared memory (sequential)',\n",
    "        'ns_per_access': sequential_time / (size // 1) * 1e9,\n",
    "        'bank_conflicts': 0\n",
    "    })\n",
    "    \n",
    "    results.append({\n",
    "        'memory_type': 'Shared memory (strided)',\n",
    "        'ns_per_access': strided_time / (size // 32) * 1e9,\n",
    "        'bank_conflicts': 32\n",
    "    })\n",
    "    \n",
    "    print(f\"  Sequential access: {sequential_time*1e6:.1f} µs total\")\n",
    "    print(f\"  Strided access (32): {strided_time*1e6:.1f} µs total\")\n",
    "    print(f\"  Bank conflict penalty: {bank_conflict_penalty:.1f}x\")\n",
    "    \n",
    "    # 3. Global memory (HBM) access\n",
    "    print(\"\\n3. Global Memory (HBM) Access:\")\n",
    "    \n",
    "    sizes_mb = [1, 10, 100]  # Test different sizes\n",
    "    \n",
    "    for size_mb in sizes_mb:\n",
    "        size = size_mb * 1024 * 1024 // 4  // 4  # FP32 elements\n",
    "        data = torch.randn(size, device='cuda')\n",
    "        \n",
    "        # Sequential read\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        acc = torch.tensor(0.0, device='cuda')\n",
    "        for i in range(0, size, 1024):  # Read in chunks\n",
    "            acc += data[i:i+1024].sum()\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        read_time = time.time() - start\n",
    "        \n",
    "        # Calculate bandwidth\n",
    "        bytes_read = size_mb * 1024 * 1024\n",
    "        bandwidth_gbs = bytes_read / read_time / 1e9\n",
    "        \n",
    "        results.append({\n",
    "            'memory_type': f'HBM {size_mb}MB read',\n",
    "            'bandwidth_gbs': bandwidth_gbs,\n",
    "            'latency_ns': read_time / (size // 1024) * 1e9\n",
    "        })\n",
    "        \n",
    "        print(f\"  {size_mb:3d} MB: {bandwidth_gbs:6.1f} GB/s, \"\n",
    "              f\"{read_time/(size//1024)*1e9:6.1f} ns per 1KB chunk\")\n",
    "    \n",
    "    # 4. Cache hierarchy demonstration\n",
    "    print(\"\\n4. Cache Hierarchy Demonstration:\")\n",
    "    \n",
    "    # Test different working set sizes\n",
    "    working_set_sizes = [\n",
    "        (\"L1\", 16 * 1024),      # 16KB - fits in L1\n",
    "        (\"L2\", 1024 * 1024),    # 1MB - fits in L2\n",
    "        (\"HBM\", 16 * 1024 * 1024)  # 16MB - exceeds cache\n",
    "    ]\n",
    "    \n",
    "    for cache_level, size_bytes in working_set_sizes:\n",
    "        size = size_bytes // 4  // 4  # FP32 elements\n",
    "        data = torch.randn(size, device='cuda')\n",
    "        \n",
    "        # Sequential access\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 100\n",
    "        stride = max(1, size // iterations)\n",
    "        acc = torch.tensor(0.0, device='cuda')\n",
    "        \n",
    "        for i in range(0, size, stride):\n",
    "            acc += data[i]\n",
    "            # Prevent compiler optimization\n",
    "            if i % 1000 == 0:\n",
    "                data[i] = acc.item()  # Force memory write\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        accesses = size // stride\n",
    "        ns_per_access = elapsed / accesses * 1e9\n",
    "        \n",
    "        results.append({\n",
    "            'memory_type': f'{cache_level} cache working set',\n",
    "            'working_set_mb': size_bytes / 1024**2,\n",
    "            'ns_per_access': ns_per_access\n",
    "        })\n",
    "        \n",
    "        print(f\"  {cache_level:3s} ({size_bytes/1024**2:5.1f} MB): {ns_per_access:6.1f} ns/access\")\n",
    "    \n",
    "    # Summary\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Memory Hierarchy Summary\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    # Create comparison table\n",
    "    print(\"\\nMemory Type                | Approx. Latency | Bandwidth   | Key Insight\")\n",
    "    print(\"-\" * 70)\n",
    "    \n",
    "    insights = {\n",
    "        'Registers': \"Fastest, but limited capacity\",\n",
    "        'Shared memory': \"Fast, but watch for bank conflicts\",\n",
    "        'L1/L2 cache': \"Automatic, but limited size\",\n",
    "        'HBM': \"Slowest, but largest capacity\"\n",
    "    }\n",
    "    \n",
    "    for res in results:\n",
    "        mem_type = res['memory_type']\n",
    "        latency = res.get('ns_per_access', 'N/A')\n",
    "        bandwidth = res.get('bandwidth_gbs', 'N/A')\n",
    "        \n",
    "        # Determine which insight applies\n",
    "        insight = ''\n",
    "        for key in insights:\n",
    "            if key in mem_type:\n",
    "                insight = insights[key]\n",
    "                break\n",
    "        \n",
    "        if isinstance(latency, float):\n",
    "            latency_str = f\"{latency:.1f} ns\"\n",
    "        else:\n",
    "            latency_str = str(latency)\n",
    "            \n",
    "        if isinstance(bandwidth, float):\n",
    "            bandwidth_str = f\"{bandwidth:.1f} GB/s\"\n",
    "        else:\n",
    "            bandwidth_str = str(bandwidth)\n",
    "        \n",
    "        print(f\"{mem_type:25s} | {latency_str:15s} | {bandwidth_str:11s} | {insight}\")\n",
    "    \n",
    "    print(\"\\nKey Takeaway: Memory hierarchy creates 1000x performance differences!\")\n",
    "    print(\"Optimization = keeping data in faster memory levels.\")\n",
    "    \n",
    "    return results"
   ]
  },
