   "source": [
    "## 2.1 Transformer Memory Access Patterns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def transformer_memory_patterns():\n",
    "    \"\"\"Analyze memory access patterns in transformer operations.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Transformer Memory Access Patterns\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    # Simulate common transformer operations\n",
    "    batch_size, seq_len, d_model, num_heads = 2, 512, 512, 8\n",
    "    head_dim = d_model // num_heads\n",
    "    \n",
    "    print(f\"\\nConfiguration: batch={batch_size}, seq_len={seq_len}, \"\n",
    "          f\"d_model={d_model}, heads={num_heads}, head_dim={head_dim}\")\n",
    "    \n",
    "    # 1. QKV projection pattern\n",
    "    print(\"\\n1. QKV Projection Memory Pattern:\")\n",
    "    \n",
    "    # Input tensor\n",
    "    x = torch.randn(batch_size, seq_len, d_model, device='cuda')\n",
    "    \n",
    "    # Weight matrices\n",
    "    W_q = torch.randn(d_model, d_model, device='cuda')\n",
    "    W_k = torch.randn(d_model, d_model, device='cuda')\n",
    "    W_v = torch.randn(d_model, d_model, device='cuda')\n",
    "    \n",
    "    # Memory access analysis\n",
    "    print(f\"  Input size: {x.numel()} elements ({x.numel() * 4 / 1024**2:.1f} MB FP32)\")\n",
    "    print(f\"  Weight size: {W_q.numel() * 3} elements ({W_q.numel() * 3 * 4 / 1024**2:.1f} MB FP32)\")\n",
    "    \n",
    "    # Compute memory traffic\n",
    "    # For x @ W_q: read x (batch*seq_len*d_model), read W_q (d_model*d_model)\n",
    "    # write Q (batch*seq_len*d_model)\n",
    "    bytes_per_element = 4  # FP32\n",
    "    \n",
    "    read_bytes = (x.numel() + W_q.numel() * 3) * bytes_per_element\n",
    "    write_bytes = x.numel() * 3 * bytes_per_element  # Q, K, V outputs\n",
    "    total_bytes = read_bytes + write_bytes\n",
    "    \n",
    "    print(f\"  Memory traffic: {total_bytes / 1024**3:.2f} GB\")\n",
    "    print(f\"  Arithmetic intensity: ~{2 * batch_size * seq_len * d_model * d_model * 3 / total_bytes:.1f} FLOPs/byte\")\n",
    "    \n",
    "    # 2. Attention computation pattern\n",
    "    print(\"\\n2. Attention Computation Pattern:\")\n",
    "    \n",
    "    # Reshaped Q, K, V\n",
    "    Q = torch.randn(batch_size, num_heads, seq_len, head_dim, device='cuda')\n",
    "    K = torch.randn(batch_size, num_heads, seq_len, head_dim, device='cuda')\n",
    "    \n",
    "    # QK^T: [batch, heads, seq_len, head_dim] × [batch, heads, head_dim, seq_len]\n",
    "    # Memory for attention matrix: batch * heads * seq_len * seq_len\n",
    "    attention_elements = batch_size * num_heads * seq_len * seq_len\n",
    "    attention_memory_mb = attention_elements * bytes_per_element / 1024**2\n",
    "    \n",
    "    print(f\"  Q shape: {tuple(Q.shape)}\")\n",
    "    print(f\"  K shape: {tuple(K.shape)}\")\n",
    "    print(f\"  Attention matrix: {attention_elements} elements ({attention_memory_mb:.1f} MB)\")\n",
    "    \n",
    "    # Memory traffic for QK^T\n",
    "    read_qk_bytes = (Q.numel() + K.numel()) * bytes_per_element\n",
    "    write_attention_bytes = attention_elements * bytes_per_element\n",
    "    total_attention_bytes = read_qk_bytes + write_attention_bytes\n",
    "    \n",
    "    flops_qkt = 2 * batch_size * num_heads * seq_len * seq_len * head_dim\n",
    "    ai_qkt = flops_qkt / total_attention_bytes\n",
    "    \n",
    "    print(f\"  QK^T memory traffic: {total_attention_bytes / 1024**3:.3f} GB\")\n",
    "    print(f\"  QK^T arithmetic intensity: {ai_qkt:.1f} FLOPs/byte\")\n",
    "    print(f\"  QK^T is {'memory-bound' if ai_qkt < 100 else 'compute-bound'}\")\n",
    "    \n",
    "    # 3. Softmax pattern\n",
    "    print(\"\\n3. Softmax Memory Pattern:\")\n",
    "    \n",
    "    # Softmax reads attention matrix, writes same size\n",
    "    softmax_read_bytes = attention_elements * bytes_per_element\n",
    "    softmax_write_bytes = attention_elements * bytes_per_element\n",
    "    softmax_total_bytes = softmax_read_bytes + softmax_write_bytes\n",
    "    \n",
    "    # Softmax FLOPs: ~3 * elements (exp, sum, division)\n",
    "    softmax_flops = 3 * attention_elements\n",
    "    ai_softmax = softmax_flops / softmax_total_bytes\n",
    "    \n",
    "    print(f\"  Softmax memory traffic: {softmax_total_bytes / 1024**3:.3f} GB\")\n",
    "    print(f\"  Softmax arithmetic intensity: {ai_softmax:.1f} FLOPs/byte\")\n",
    "    print(f\"  Softmax is {'memory-bound' if ai_softmax < 100 else 'compute-bound'}\")\n",
    "    \n",
    "    # 4. FFN pattern\n",
    "    print(\"\\n4. FFN Memory Pattern:\")\n",
    "    \n",
    "    d_ff = d_model * 4  # Typical expansion\n",
    "    \n",
    "    # fc1: x @ W1 where x: [batch*seq_len, d_model], W1: [d_model, d_ff]\n",
    "    fc1_read_bytes = (batch_size * seq_len * d_model + d_model * d_ff) * bytes_per_element\n",
    "    fc1_write_bytes = batch_size * seq_len * d_ff * bytes_per_element\n",
    "    fc1_total_bytes = fc1_read_bytes + fc1_write_bytes\n",
    "    \n",
    "    fc1_flops = 2 * batch_size * seq_len * d_model * d_ff\n",
    "    ai_fc1 = fc1_flops / fc1_total_bytes\n",
    "    \n",
    "    print(f\"  FFN fc1 memory traffic: {fc1_total_bytes / 1024**3:.3f} GB\")\n",
    "    print(f\"  FFN fc1 arithmetic intensity: {ai_fc1:.1f} FLOPs/byte\")\n",
    "    print(f\"  FFN fc1 is {'memory-bound' if ai_fc1 < 100 else 'compute-bound'}\")\n",
    "    \n",
    "    # 5. Overall analysis\n",
    "    print(\"\\n5. Overall Transformer Memory Analysis:\")\n",
    "    \n",
    "    total_flops = (\n",
    "        2 * batch_size * seq_len * d_model * d_model * 3 +  # QKV projections\n",
    "        2 * batch_size * num_heads * seq_len * seq_len * head_dim +  # QK^T\n",
    "        3 * batch_size * num_heads * seq_len * seq_len +  # Softmax\n",
    "        2 * batch_size * num_heads * seq_len * seq_len * head_dim +  # AV\n",
    "        2 * batch_size * seq_len * d_model * d_model +  # Output projection\n",
    "        2 * batch_size * seq_len * d_model * d_ff * 2  # FFN (fc1 + fc2)\n",
    "    )\n",
    "    \n",
    "    # Estimate total memory traffic\n",
    "    total_memory_traffic_gb = (\n",
    "        total_bytes +  # QKV\n",
    "        total_attention_bytes +  # QK^T\n",
    "        softmax_total_bytes +  # Softmax\n",
    "        total_attention_bytes +  # AV (same as QK^T)\n",
    "        total_bytes / 3 +  # Output projection (~1/3 of QKV)\n",
    "        fc1_total_bytes * 2  # FFN (fc1 + similar for fc2)\n",
    "    ) / 1024**3\n",
    "    \n",
    "    overall_ai = total_flops / (total_memory_traffic_gb * 1024**3)\n",
    "    \n",
    "    print(f\"  Total estimated FLOPs: {total_flops / 1e9:.1f} GFLOPs\")\n",
    "    print(f\"  Total memory traffic: {total_memory_traffic_gb:.2f} GB\")\n",
    "    print(f\"  Overall arithmetic intensity: {overall_ai:.1f} FLOPs/byte\")\n",
    "    \n",
    "    # GPU comparison\n",
    "    if torch.cuda.is_available():\n",
    "        gpu = torch.cuda.get_device_properties(0)\n",
    "        \n",
    "        # Estimate bandwidth\n",
    "        peak_bandwidth_gbs = {\n",
    "            'RTX 4090': 1008,\n",
    "            'A100': 2000,\n",
    "            'V100': 900,\n",
    "            'RTX 3090': 936\n,
    "        }.get(gpu.name, 500)\n",
    "        \n",
    "        # Roofline analysis\n",
    "        compute_bound_threshold = peak_tflops * 1000 / peak_bandwidth_gbs  # TFLOPS to match bandwidth\n",
    "        \n",
    "        print(f\"\\n  GPU: {gpu.name}\")\n",
    "        print(f\"  Peak bandwidth: {peak_bandwidth_gbs:.0f} GB/s\")\n",
    "        print(f\"  Compute-bound threshold: {compute_bound_threshold:.0f} FLOPs/byte\")\n",
    "        \n",
    "        if overall_ai > compute_bound_threshold:\n",
    "            print(f\"  This workload is COMPUTE-BOUND on {gpu.name}\")\n",
    "            print(\"    → Optimize for FLOP efficiency\")\n",
    "            print(\"    → Use tensor cores, increase occupancy\")\n",
    "        else:\n",
    "            print(f\"  This workload is MEMORY-BOUND on {gpu.name}\")\n",
    "            print(\"    → Optimize memory access patterns\")\n",
    "            print(\"    → Reduce data movement, improve cache usage\")\n",
    "    \n",
    "    print(\"\\nKey Transformer Memory Insights:\")\n",
    "    print(\"1. Attention is memory-bound (low arithmetic intensity)\")\n",
    "    print(\"2. Linear layers are compute-bound (high arithmetic intensity)\")\n",
    "    print(\"3. Softmax is extremely memory-bound\")\n",
    "    print(\"4. Overall workload often memory-bound due to attention\")\n",
    "    \n",
    "    return {\n",
    "        'qkv_ai': ai_qkt,\n",
    "        'softmax_ai': ai_softmax,\n",
    "        'ffn_ai': ai_fc1,\n",
    "        'overall_ai': overall_ai,\n",
    "        'attention_memory_mb': attention_memory_mb\n",
    "    }"
   ]
