    "def memory_optimization_experiments():\n",
    "    \"\"\"Experiment with different memory optimization techniques.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Memory Optimization Experiments\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    # 1. Precision reduction\n",
    "    print(\"\\n1. Precision Reduction (FP32 → FP16 → INT8):\")\n",
    "    \n",
    "    size = 1024 * 1024 * 100  # 100MB\n",
    "    \n",
    "    precisions = [\n",
    "        ('FP32', torch.float32, 4),\n",
    "        ('FP16', torch.float16, 2),\n",
    "        # ('INT8', torch.int8, 1)  # Requires quantization\n",
    "    ]\n",
    "    \n",
    "    for name, dtype, bytes_per_element in precisions:\n",
    "        data = torch.randn(size // bytes_per_element, device='cuda', dtype=dtype)\n",
    "        \n",
    "        # Time sum operation\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 100\n",
    "        for _ in range(iterations):\n",
    "            _ = data.sum()\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        bandwidth_gbs = (size * iterations) / elapsed / 1e9\n",
    "        memory_saving = 4 / bytes_per_element  # Compared to FP32\n",
    "        \n",
    "        print(f\"  {name}: {bandwidth_gbs:.1f} GB/s, {memory_saving:.1f}x memory saving\")\n",
    "    \n",
    "    # 2. Kernel fusion simulation\n",
    "    print(\"\\n2. Kernel Fusion (LayerNorm + Residual):\")\n",
    "    \n",
    "    batch_size, seq_len, d_model = 2, 512, 512\n",
    "    \n",
    "    # Separate operations\n",
    "    x = torch.randn(batch_size, seq_len, d_model, device='cuda')\n",
    "    residual = torch.randn(batch_size, seq_len, d_model, device='cuda')\n",
    "    \n",
    "    # LayerNorm weights\n",
    "    weight = torch.randn(d_model, device='cuda')\n",
    "    bias = torch.randn(d_model, device='cuda')\n",
    "    eps = 1e-5\n",
    "    \n",
    "    # Time separate operations\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    iterations = 100\n",
    "    for _ in range(iterations):\n",
    "        # LayerNorm\n",
    "        mean = x.mean(dim=-1, keepdim=True)\n",
    "        var = x.var(dim=-1, keepdim=True, unbiased=False)\n",
    "        x_normalized = (x - mean) / torch.sqrt(var + eps)\n",
    "        x_scaled = x_normalized * weight + bias\n",
    "        \n",
    "        # Residual add\n",
    "        result = x_scaled + residual\n",
    "        \n",
    "        # Force computation\n",
    "        _ = result.sum()\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    separate_time = time.time() - start\n",
    "    \n",
    "    # Fused operation (simulated - in reality would be custom kernel)\n",
    "    # We'll simulate by doing everything in one loop\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    for _ in range(iterations):\n",
    "        # Simulated fused operation\n",
    "        mean = x.mean(dim=-1, keepdim=True)\n",
    "        var = x.var(dim=-1, keepdim=True, unbiased=False)\n",
    "        # In fused kernel: compute and add residual in same memory pass\n",
    "        result = (x - mean) / torch.sqrt(var + eps) * weight + bias + residual\n",
    "        _ = result.sum()\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    fused_time = time.time() - start\n",
    "    \n",
    "    speedup = separate_time / fused_time\n",
    "    \n",
    "    print(f\"  Separate kernels: {separate_time:.3f}s\")\n",
    "    print(f\"  Fused kernel (simulated): {fused_time:.3f}s\")\n",
    "    print(f\"  Speedup: {speedup:.2f}x\")\n",
    "    print(f\"  Memory traffic reduction: ~2x (avoid intermediate storage)\")\n",
    "    \n",
    "    # 3. Gradient checkpointing simulation\n",
    "    print(\"\\n3. Gradient Checkpointing (Memory vs Compute Trade-off):\")\n",
    "    \n",
    "    # Simulate a 4-layer network\n",
    "    layer_size = 1024 * 1024  # 1MB per activation\n",
    "    \n",
    "    # Without checkpointing: store all activations\n",
    "    memory_without_checkpointing = 4 * layer_size * 4 / 1024**2  # 4 layers, FP32\n",
    "    compute_without_checkpointing = 4  # 4 forward passes\n",
    "    \n",
    "    # With checkpointing: store only 1 activation, recompute others\n",
    "    memory_with_checkpointing = 1 * layer_size * 4 / 1024**2  # 1 checkpoint\n",
    "    compute_with_checkpointing = 4 + 3  # Forward + recompute for gradient\n",
    "    \n",
    "    print(f\"  Without checkpointing: {memory_without_checkpointing:.1f} MB memory, \"\n",
    "          f\"{compute_without_checkpointing} FLOP units\")\n",
    "    print(f\"  With checkpointing: {memory_with_checkpointing:.1f} MB memory, \"\n",
    "          f\"{compute_with_checkpointing} FLOP units\")\n",
    "    print(f\"  Memory reduction: {memory_without_checkpointing/memory_with_checkpointing:.1f}x\")\n",
    "    print(f\"  Compute increase: {compute_with_checkpointing/compute_without_checkpointing:.1f}x\")\n",
    "    \n",
    "    # 4. Memory access pattern optimization\n",
    "    print(\"\\n4. Memory Access Pattern Optimization:\")\n",
    "    \n",
    "    # Test different data layouts for attention\n",
    "    batch, heads, seq_len, head_dim = 2, 8, 512, 64\n",
    "    \n",
    "    # Layout 1: [batch, heads, seq_len, head_dim] (typical)\n",
    "    layout1 = torch.randn(batch, heads, seq_len, head_dim, device='cuda')\n",
    "    \n",
    "    # Layout 2: [batch, seq_len, heads, head_dim] (might be better for some ops)\n",
    "    layout2 = layout1.permute(0, 2, 1, 3).contiguous()\n",
    "    \n",
    "    # Time attention-like operation\n",
    "    # For each head, compute something\n",
    "    \n",
    "    # Layout 1 access\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    for _ in range(100):\n",
    "        # Access by head first\n",
    "        for h in range(heads):\n",
    "            head_data = layout1[:, h, :, :]\n",
    "            _ = head_data.sum()\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    layout1_time = time.time() - start\n",
    "    \n",
    "    # Layout 2 access\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    for _ in range(100):\n",
    "        # Access by sequence position first\n",
    "        for s in range(seq_len):\n",
    "            pos_data = layout2[:, s, :, :]\n",
    "            _ = pos_data.sum()\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    layout2_time = time.time() - start\n",
    "    \n",
    "    print(f\"  Layout [batch, heads, seq, dim]: {layout1_time:.3f}s\")\n",
    "    print(f\"  Layout [batch, seq, heads, dim]: {layout2_time:.3f}s\")\n",
    "    print(f\"  Speed difference: {layout1_time/layout2_time:.2f}x\")\n",
    "    print(f\"  Optimal layout depends on access pattern!\")\n",
    "    \n",
    "    # 5. Zero-copy and pinned memory\n",
    "    print(\"\\n5. Zero-Copy and Pinned Memory:\")\n",
    "    \n",
    "    size = 1024 * 1024 * 10  # 10MB\n",
    "    \n",
    "    # Regular CPU memory\n",
    "    cpu_data = torch.randn(size // 4)\n",
    "    \n",
    "    # Pinned (page-locked) memory\n",
    "    pinned_data = torch.randn(size // 4, pin_memory=True)\n",
    "    \n",
    "    # Time transfers\n",
    "    # Regular memory\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    gpu_data = cpu_data.cuda()\n",
    "    torch.cuda.synchronize()\n",
    "    regular_time = time.time() - start\n",
    "    \n",
    "    # Pinned memory\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    gpu_pinned = pinned_data.cuda()\n",
    "    torch.cuda.synchronize()\n",
    "    pinned_time = time.time() - start\n",
    "    \n",
    "    speedup = regular_time / pinned_time\n",
    "    bandwidth_regular = size / regular_time / 1e9\n",
    "    bandwidth_pinned = size / pinned_time / 1e9\n",
    "    \n",
    "    print(f\"  Regular memory: {regular_time*1000:.1f} ms, {bandwidth_regular:.1f} GB/s\")\n",
    "    print(f\"  Pinned memory: {pinned_time*1000:.1f} ms, {bandwidth_pinned:.1f} GB/s\")\n",
    "    print(f\"  Speedup: {speedup:.2f}x\")\n",
    "    print(f\"  Use pinned memory for frequent CPU-GPU transfers\")\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Memory Optimization Summary\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    print(\"\\nTop Memory Optimization Techniques:\")\n",
    "    print(\"1. Precision reduction: FP16 = 2x memory saving, often 2x speed\")\n",
    "    print(\"2. Kernel fusion: Combine ops to reduce memory traffic\")\n",
    "    print(\"3. Gradient checkpointing: Trade compute for memory\")\n",
    "    print(\"4. Optimize data layout: Match access patterns\")\n",
    "    print(\"5. Pinned memory: Faster CPU-GPU transfers\")\n",
    "    print(\"6. Cache blocking: Work on tiles that fit in cache\")\n",
    "    print(\"7. Memory coalescing: Ensure contiguous access\")\n",
