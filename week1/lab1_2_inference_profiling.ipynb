    "## 1.2 PyTorch Profiler - Professional Profiling"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def pytorch_profiler_experiment():\n",
    "    \"\"\"Use PyTorch's built-in profiler for detailed insights.\"\"\"\n",
    "    \n",
    "    if not torch.cuda.is_available():\n",
    "        print(\"CUDA not available - skipping PyTorch profiler\")\n",
    "        return\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"PyTorch Profiler Experiment\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    model.eval()\n",
    "    \n",
    "    x = torch.randn(1, 512, 512, device='cuda')\n",
    "    \n",
    "    # Configure profiler\n",
    "    print(\"\\n1. Configuring profiler with:\")\n",
    "    print(\"   - CUDA activities\")\n",
    "    print(\"   - Memory profiling\")\n",
    "    print(\"   - Record shapes\")\n",
    "    print(\"   - With stack traces\")\n",
    "    \n",
    "    # Run profiler\n",
    "    print(\"\\n2. Running profiler (this may take a moment)...\")\n",
    "    \n",
    "    with torch.profiler.profile(\n",
    "        activities=[\n",
    "            torch.profiler.ProfilerActivity.CPU,\n",
    "            torch.profiler.ProfilerActivity.CUDA,\n",
    "        ],\n",
    "        schedule=torch.profiler.schedule(\n",
    "            wait=1,  # Skip first iteration\n",
    "            warmup=1,  # Warmup for 1 iteration\n",
    "            active=3,  # Profile 3 iterations\n",
    "            repeat=1   # Don't repeat\n",
    "        ),\n",
    "        on_trace_ready=torch.profiler.tensorboard_trace_handler('./profiler_logs'),\n",
    "        record_shapes=True,\n",
    "        profile_memory=True,\n",
    "        with_stack=True,\n",
    "        with_flops=True  # Estimate FLOPs\n",
    "    ) as prof:\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            for step in range(5):  # Run 5 steps total\n",
    "                _ = model(x)\n",
    "                prof.step()  # Signal profiler after each step\n",
    "    \n",
    "    print(\"\\n3. Profiler Results Summary:\")\n",
    "    print(\"=\" * 50)\n",
    "    \n",
    "    # Get key averages table\n",
    "    print(\"\\nTop operations by CUDA time:\")\n",
    "    print(prof.key_averages().table(sort_by=\"cuda_time_total\", row_limit=10))\n",
    "    \n",
    "    # Get memory statistics\n",
    "    print(\"\\nMemory events:\")\n",
    "    memory_events = [\n",
    "        evt for evt in prof.key_averages() \n",
    "        if '[memory]' in evt.name or evt.cuda_memory_usage > 0\n",
    "    ]\n",
    "    \n",
    "    for evt in memory_events[:5]:  # Show top 5\n",
    "        print(f\"  {evt.name:40s} {evt.cuda_memory_usage / 1024**2:8.1f} MB\")\n",
    "    \n",
    "    # Get FLOP estimates\n",
    "    print(\"\\nFLOP estimates:\")\n",
    "    flop_events = [evt for evt in prof.key_averages() if hasattr(evt, 'flops') and evt.flops > 0]\n",
    "    \n",
    "    total_flops = sum(evt.flops for evt in flop_events)\n",
    "    print(f\"  Total estimated FLOPs: {total_flops / 1e9:.2f} GFLOPs\")\n",
    "    \n",
    "    # Save detailed results for later analysis\n",
    "    print(\"\\n4. Saving detailed results...\")\n",
    "    \n",
    "    # Export to JSON for further analysis\n",
    "    events = prof.key_averages()\n",
    "    \n",
    "    results = []\n",
    "    for evt in events:\n",
    "        results.append({\n",
    "            'name': evt.name,\n",
    "            'cpu_time': evt.cpu_time_total,\n",
    "            'cuda_time': evt.cuda_time_total,\n",
    "            'calls': evt.count,\n",
    "            'memory': evt.cuda_memory_usage,\n",
    "            'flops': getattr(evt, 'flops', 0)\n",
    "        })\n",
    "    \n",
    "    with open('profiler_results.json', 'w') as f:\n",
    "        json.dump(results, f, indent=2)\n",
    "    \n",
    "    print(\"   Saved to profiler_results.json\")\n",
    "    print(\"   TensorBoard logs saved to ./profiler_logs\")\n",
    "    print(\"   Run: tensorboard --logdir=./profiler_logs to visualize\")\n",
    "    \n",
    "    return prof\n",
    "\n",
    "# Run PyTorch profiler\n",
    "profiler = pytorch_profiler_experiment()"
   ]
  },
