    "# Part 2: Bottleneck Analysis - Finding What to Optimize"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2.1 Bottleneck Identification"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def identify_bottlenecks():\n",
    "    \"\"\"Identify compute vs memory bottlenecks.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Bottleneck Identification\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    model.eval()\n",
    "    \n",
    "    # Test different sequence lengths\n",
    "    seq_lengths = [128, 256, 512, 1024, 2048]\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    for seq_len in seq_lengths:\n",
    "        try:\n",
    "            x = torch.randn(1, seq_len, 512, device='cuda')\n",
    "            \n",
    "            # Warmup\n",
    "            with torch.no_grad():\n",
    "                for _ in range(5):\n",
    "                    _ = model(x)\n",
    "            \n",
    "            # Time forward pass\n",
    "            torch.cuda.synchronize()\n",
    "            start = time.time()\n",
    "            \n",
    "            with torch.no_grad():\n",
    "                for _ in range(50):\n",
    "                    _ = model(x)\n",
    "            \n",
    "            torch.cuda.synchronize()\n",
    "            elapsed = time.time() - start\n",
    "            \n",
    "            avg_ms = elapsed / 50 * 1000\n",
    "            \n",
    "            # Measure memory\n",
    "            torch.cuda.reset_peak_memory_stats()\n",
    "            with torch.no_grad():\n",
    "                _ = model(x)\n",
    "            \n",
    "            peak_mb = torch.cuda.max_memory_allocated() / 1024**2\n",
    "            \n",
    "            # Calculate FLOPs (simplified estimate)\n",
    "            # Attention: O(n²d) where n=seq_len, d=head_dim=64\n",
    "            attention_flops = 2 * seq_len * seq_len * 64 * 2  # QK^T and AV\n",
    "            # Linear layers: O(nd²) where d=512\n",
    "            linear_flops = 4 * seq_len * 512 * 512 * 2  # QKV + out projections\n",
    "            # FFN: O(nd²) with expansion factor 4\n",
    "            ffn_flops = 2 * seq_len * 512 * 2048 * 2  # fc1 and fc2\n",
    "            \n",
    "            total_flops = attention_flops + linear_flops + ffn_flops\n",
    "            flops_per_sec = total_flops / (avg_ms / 1000)\n",
    "            \n",
    "            results.append({\n",
    "                'seq_len': seq_len,\n",
    "                'latency_ms': avg_ms,\n",
    "                'memory_mb': peak_mb,\n",
    "                'flops_g': total_flops / 1e9,\n",
    "                'flops_per_sec': flops_per_sec,\n",
    "                'tokens_per_sec': seq_len / (avg_ms / 1000)\n",
    "            })\n",
    "            \n",
    "            print(f\"  seq_len={seq_len:4d}: {avg_ms:6.1f} ms, {peak_mb:6.1f} MB, \"\n",
    "                  f\"{total_flops/1e9:5.1f} GFLOPs\")\n",
    "            \n",
    "        except RuntimeError as e:\n",
    "            print(f\"  seq_len={seq_len}: FAILED - {str(e)}\")\n",
    "            break\n",
    "    \n",
    "    # Analyze bottlenecks\n",
    "    if len(results) >= 3:\n",
    "        print(\"\\nBottleneck Analysis:\")\n",
    "        print(\"-\" * 50)\n",
    "        \n",
    "        # Check scaling behavior\n",
    "        first = results[0]\n",
    "        last = results[-1]\n",
    "        \n",
    "        seq_ratio = last['seq_len'] / first['seq_len']\n",
    "        latency_ratio = last['latency_ms'] / first['latency_ms']\n",
    "        memory_ratio = last['memory_mb'] / first['memory_mb']\n",
    "        flops_ratio = last['flops_g'] / first['flops_g']\n",
    "        \n",
    "        print(f\"  Sequence length increased by: {seq_ratio:.1f}x\")\n",
    "        print(f\"  Latency increased by: {latency_ratio:.1f}x\")\n",
    "        print(f\"  Memory increased by: {memory_ratio:.1f}x\")\n",
    "        print(f\"  FLOPs increased by: {flops_ratio:.1f}x\")\n",
    "        \n",
    "        # Determine bottleneck type\n",
    "        print(\"\\nBottleneck Type:\")\n",
    "        \n",
    "        if latency_ratio > flops_ratio * 1.2:\n",
    "            print(\"  ⚠️  Memory-bound: Latency growing faster than FLOPs\")\n",
    "            print(\"     → Optimize memory access patterns\")\n",
    "            print(\"     → Consider memory bandwidth optimizations\")\n",
    "        elif latency_ratio < flops_ratio * 0.8:\n",
    "            print(\"  ⚠️  Compute-bound: Latency growing slower than FLOPs\")\n",
    "            print(\"     → GPU utilization improving with size\")\n",
    "            print(\"     → Good scaling, but watch memory\")\n",
    "        else:\n",
    "            print(\"  ✅ Balanced: Latency scales with FLOPs\")\n",
    "            print(\"     → Good balance between compute and memory\")\n",
    "        \n",
    "        # Check memory scaling\n",
    "        expected_memory_scaling = seq_ratio  # Linear for activations\n",
    "        actual_memory_scaling = memory_ratio\n",
    "        \n",
    "        if actual_memory_scaling > expected_memory_scaling * 1.5:\n",
    "            print(\"\\n  ⚠️  Memory scaling worse than linear\")\n",
    "            print(\"     → Likely attention matrix O(n²) memory\")\n",
    "            print(\"     → Consider memory-efficient attention\")\n",
    "    \n",
    "    return results"
   ]
  },
