   "source": [
    "def hardware_benchmarking():\n",
    "    \"\"\"Benchmark different hardware aspects.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Hardware Benchmarking\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    benchmarks = []\n",
    "    \n",
    "    # 1. Matrix multiplication benchmark\n",
    "    print(\"\\n1. Matrix Multiplication Benchmark:\")\n",
    "    \n",
    "    sizes = [256, 512, 1024, 2048, 4096]\n",
    "    for size in sizes:\n",
    "        A = torch.randn(size, size, device='cuda', dtype=torch.float16)\n",
    "        B = torch.randn(size, size, device='cuda', dtype=torch.float16)\n",
    "        \n",
    "        # Warmup\n",
    "        for _ in range(5):\n",
    "            _ = torch.matmul(A, B)\n",
    "        \n",
    "        # Time\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 10\n",
    "        for _ in range(iterations):\n",
    "            _ = torch.matmul(A, B)\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        avg_ms = elapsed / iterations * 1000\n",
    "        flops = 2 * size ** 3\n",
    "        flops_per_sec = flops * iterations / elapsed\n",
    "        tflops = flops_per_sec / 1e12\n",
    "        \n",
    "        benchmarks.append({\n",
    "            'test': f'MatMul {size}x{size}',\n",
    "            'size': size,\n",
    "            'latency_ms': avg_ms,\n",
    "            'tflops': tflops\n",
    "        })\n",
    "        \n",
    "        print(f\"  {size:4d}x{size:<4d}: {avg_ms:7.2f} ms, {tflops:6.2f} TFLOPS\")\n",
    "    \n",
    "    # 2. Memory bandwidth benchmark\n",
    "    print(\"\\n2. Memory Bandwidth Benchmark:\")\n",
    "    \n",
    "    sizes_mb = [10, 100, 1000]  # MB\n",
    "    for size_mb in sizes_mb:\n",
    "        size = size_mb * 1024 * 1024 // 2  // 2  # FP16 elements\n",
    "        data = torch.randn(size, device='cuda', dtype=torch.float16)\n",
    "        \n",
    "        # Sequential access\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 100\n",
    "        acc = torch.tensor(0.0, device='cuda')\n",
    "        for _ in range(iterations):\n",
    "            acc += data.sum()\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        bytes_transferred = size * 2 * iterations * 2  # Read and reduction\n",
    "        bandwidth_gbs = bytes_transferred / elapsed / 1e9\n",
    "        \n",
    "        benchmarks.append({\n",
    "            'test': f'Memory {size_mb}MB',\n",
    "            'size': size_mb,\n",
    "            'bandwidth_gbs': bandwidth_gbs\n",
    "        })\n",
    "        \n",
    "        print(f\"  {size_mb:4d} MB: {bandwidth_gbs:6.1f} GB/s\")\n",
    "    \n",
    "    # 3. Kernel launch overhead\n",
    "    print(\"\\n3. Kernel Launch Overhead:\")\n",
    "    \n",
    "    # Small operation to measure overhead\n",
    "    x = torch.tensor([1.0], device='cuda')\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    iterations = 10000\n",
    "    for _ in range(iterations):\n",
    "        _ = x + 1\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    elapsed = time.time() - start\n",
    "    \n",
    "    overhead_us = elapsed / iterations * 1e6\n",
    "    \n",
    "    benchmarks.append({\n",
    "        'test': 'Kernel launch',\n",
    "        'overhead_us': overhead_us\n",
    "    })\n",
    "    \n",
    "    print(f\"  Kernel launch overhead: {overhead_us:.2f} µs\")\n",
    "    \n",
    "    # 4. CPU-GPU transfer\n",
    "    print(\"\\n4. CPU-GPU Transfer:\")\n",
    "    \n",
    "    sizes_mb = [1, 10, 100]\n",
    "    for size_mb in sizes_mb:\n",
    "        size = size_mb * 1024 * 1024 // 4  // 4  # FP32 elements\n",
    "        cpu_data = torch.randn(size)\n",
    "        \n",
    "        # CPU → GPU\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        gpu_data = cpu_data.cuda()\n",
    "        torch.cuda.synchronize()\n",
    "        cpu_to_gpu = time.time() - start\n",
    "        \n",
    "        # GPU → CPU\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        cpu_data_back = gpu_data.cpu()\n",
    "        torch.cuda.synchronize()\n",
    "        gpu_to_cpu = time.time() - start\n",
    "        \n",
    "        bandwidth_to_gpu = (size_mb * 1024 * 1024) / cpu_to_gpu / 1e9\n",
    "        bandwidth_from_gpu = (size_mb * 1024 * 1024) / gpu_to_cpu / 1e9\n",
    "        \n",
    "        benchmarks.append({\n",
    "            'test': f'Transfer {size_mb}MB to GPU',\n",
    "            'size': size_mb,\n",
    "            'bandwidth_gbs': bandwidth_to_gpu\n",
    "        })\n",
    "        benchmarks.append({\n",
    "            'test': f'Transfer {size_mb}MB from GPU',\n",
    "            'size': size_mb,\n",
    "            'bandwidth_gbs': bandwidth_from_gpu\n",
    "        })\n",
    "        \n",
    "        print(f\"  {size_mb:3d} MB: To GPU={bandwidth_to_gpu:5.1f} GB/s, \"\n",
    "              f\"From GPU={bandwidth_from_gpu:5.1f} GB/s\")\n",
    "    \n",
    "    # Summary\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Hardware Characterization Summary\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    if torch.cuda.is_available():\n",
    "        gpu = torch.cuda.get_device_properties(0)\n",
    "        print(f\"\\nGPU: {gpu.name}\")\n",
    "        print(f\"Memory: {gpu.total_memory / 1024**3:.1f} GB\")\n",
    "        \n",
    "        # Find best matmul performance\n",
    "        matmul_results = [b for b in benchmarks if 'MatMul' in b['test']]\n",
    "        if matmul_results:\n",
    "            best_matmul = max(matmul_results, key=lambda x: x['tflops'])\n",
    "            print(f\"Peak MatMul: {best_matmul['tflops']:.2f} TFLOPS at {best_matmul['test']}\")\n",
    "        \n",
    "        # Find memory bandwidth\n",
    "        memory_results = [b for b in benchmarks if 'Memory' in b['test']]\n",
    "        if memory_results:\n",
    "            best_memory = max(memory_results, key=lambda x: x.get('bandwidth_gbs', 0))\n",
    "            print(f\"Memory bandwidth: {best_memory['bandwidth_gbs']:.1f} GB/s\")\n",
    "    \n",
    "    print(\"\\nImplications for Transformer Inference:\")\n",
    "    print(\"1. Large matmuls achieve high FLOP/s (good for linear layers)\")\n",
    "    print(\"2. Memory bandwidth limits attention operations\")\n",
    "    print(\"3. CPU-GPU transfer is slow - keep data on GPU\")\n",
    "    print(\"4. Kernel launch overhead matters for small operations\")\n",
    "    \n",
    "    return benchmarks"
   ]
  },
