   "source": [
    "## 1.1 Simple Timing - The Basics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def basic_timing_experiment():\n",
    "    \"\"\"Basic timing measurements to establish fundamentals.\"\"\"\n",
    "    \n",
    "    print(\"Basic Timing Experiment\")\n",
    "    print(\"=\" * 60)\n",
    "    \n",
    "    # Create model\n",
    "    model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    model.eval()\n",
    "    \n",
    "    # Create input\n",
    "    x = torch.randn(1, 512, 512, device='cuda')\n",
    "    \n",
    "    # Warmup (critical for GPU timing)\n",
    "    print(\"\\n1. Warmup Phase:\")\n",
    "    with torch.no_grad():\n",
    "        for i in range(10):\n",
    "            _ = model(x)\n",
    "    print(\"   Warmup complete (10 iterations)\")\n",
    "    \n",
    "    # Simple timing\n",
    "    print(\"\\n2. Simple Timing (100 iterations):\")\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for i in range(100):\n",
    "            _ = model(x)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    elapsed = time.time() - start\n",
    "    \n",
    "    avg_ms = elapsed / 100 * 1000\n",
    "    iterations_per_sec = 100 / elapsed\n",
    "    \n",
    "    print(f\"   Total time: {elapsed:.3f}s\")\n",
    "    print(f\"   Average latency: {avg_ms:.2f} ms\")\n",
    "    print(f\"   Iterations/sec: {iterations_per_sec:.1f}\")\n",
    "    \n",
    "    # Memory measurement\n",
    "    print(\"\\n3. Memory Measurement:\")\n",
    "    \n",
    "    torch.cuda.reset_peak_memory_stats()\n",
    "    with torch.no_grad():\n",
    "        _ = model(x)\n",
    "    \n",
    "    peak_mb = torch.cuda.max_memory_allocated() / 1024**2\n",
    "    current_mb = torch.cuda.memory_allocated() / 1024**2\n",
    "    \n",
    "    print(f\"   Peak memory: {peak_mb:.1f} MB\")\n",
    "    print(f\"   Current memory: {current_mb:.1f} MB\")\n",
    "    \n",
    "    # Throughput calculation\n",
    "    tokens_per_sec = (1 * 512) / (avg_ms / 1000)\n",
    "    print(f\"   Throughput: {tokens_per_sec:.0f} tokens/sec\")\n",
    "    \n",
    "    return {\n",
    "        'avg_ms': avg_ms,\n",
    "        'peak_mb': peak_mb,\n",
    "        'tokens_per_sec': tokens_per_sec\n",
    "    }\n",
    "\n",
    "# Run basic timing\n",
    "basic_results = basic_timing_experiment()"
   ]
  },
