   "source": [
    "## 2.2 Compute vs Memory Bound Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_memory_analysis():\n",
    "    \"\"\"Analyze whether operations are compute-bound or memory-bound.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Compute vs Memory Bound Analysis\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    if not torch.cuda.is_available():\n",
    "        print(\"CUDA not available - skipping analysis\")\n",
    "        return\n",
    "    \n",
    "    # Get GPU specs\n",
    "    gpu = torch.cuda.get_device_properties(0)\n",
    "    \n",
    "    # Theoretical limits\n",
    "    peak_tflops = gpu.multi_processor_count * gpu.clock_rate * 2 / 1e3  # Approximate\n",
    "    peak_bandwidth_gbs = {\n",
    "        'RTX 4090': 1008,\n",
    "        'A100': 2000,\n",
    "        'V100': 900,\n",
    "        'RTX 3090': 936,\n",
    "        'RTX 4080': 716\n",
    }.get(gpu.name, 500)  # Default estimate\n",
    "    \n",
    "    print(f\"GPU: {gpu.name}\")\n",
    "    print(f\"  Theoretical peak: {peak_tflops:.1f} TFLOPS (FP16)\")\n",
    "    print(f\"  Memory bandwidth: {peak_bandwidth_gbs:.0f} GB/s\")\n",
    "    \n",
    "    # Test different operations\n",
    "    operations = [\n",
    "        ('Small MatMul', (256, 256, 256)),\n",
    "        ('Medium MatMul', (1024, 1024, 1024)),\n",
    "        ('Large MatMul', (4096, 4096, 4096)),\n",
    "        ('Attention-like', (512, 512, 64)),  # n=512, d=64\n",
    "        ('Linear-like', (512, 512, 512)),   # n=512, d=512\n",
    "    ]\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    for op_name, (m, n, k) in operations:\n",
    "        # Create matrices\n",
    "        A = torch.randn(m, k, device='cuda', dtype=torch.float16)\n",
    "        B = torch.randn(k, n, device='cuda', dtype=torch.float16)\n",
    "        \n",
    "        # Warmup\n",
    "        for _ in range(10):\n",
    "            _ = torch.matmul(A, B)\n",
    "        \n",
    "        # Time it\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 100\n",
    "        for _ in range(iterations):\n",
    "            _ = torch.matmul(A, B)\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        avg_ms = elapsed / iterations * 1000\n",
    "        \n",
    "        # Calculate metrics\n",
    "        flops = 2 * m * n * k  # FLOPs for matmul\n",
    "        flops_per_sec = flops * iterations / elapsed\n",
    "        tflops = flops_per_sec / 1e12\n",
    "        \n",
    "        # Bytes transferred (simplified)\n",
    "        bytes_transferred = (m * k + k * n + m * n) * 2  # FP16 = 2 bytes\n",
    "        bandwidth_gbs = bytes_transferred * iterations / elapsed / 1e9\n",
    "        \n",
    "        # Arithmetic intensity\n",
    "        arithmetic_intensity = flops / bytes_transferred  # FLOPs/byte\n",
    "        \n",
    "        # Determine bound\n",
    "        compute_bound = tflops / peak_tflops > bandwidth_gbs / peak_bandwidth_gbs\n",
    "        bound_type = \"Compute-bound\" if compute_bound else \"Memory-bound\"\n",
    "        \n",
    "        results.append({\n",
    "            'operation': op_name,\n",
    "            'shape': (m, n, k),\n",
    "            'latency_ms': avg_ms,\n",
    "            'tflops': tflops,\n",
    "            'bandwidth_gbs': bandwidth_gbs,\n",
    "            'arithmetic_intensity': arithmetic_intensity,\n",
    "            'bound_type': bound_type,\n",
    "            'compute_utilization': tflops / peak_tflops * 100,\n",
    "            'memory_utilization': bandwidth_gbs / peak_bandwidth_gbs * 100\n",
    "        })\n",
    "        \n",
    "        print(f\"\\n{op_name} ({m}x{k} @ {k}x{n}):\")\n",
    "        print(f\"  Latency: {avg_ms:.2f} ms\")\n",
    "        print(f\"  Performance: {tflops:.2f} TFLOPS ({tflops/peak_tflops*100:.1f}% of peak)\")\n",
    "        print(f\"  Bandwidth: {bandwidth_gbs:.1f} GB/s ({bandwidth_gbs/peak_bandwidth_gbs*100:.1f}% of peak)\")\n",
    "        print(f\"  Arithmetic intensity: {arithmetic_intensity:.1f} FLOPs/byte\")\n",
    "        print(f\"  Bound type: {bound_type}\")\n",
    "    \n",
    "    # Roofline analysis\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Roofline Analysis\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    # Create roofline plot\n",
    "    plt.figure(figsize=(10, 6))\n",
    "    \n",
    "    # Plot roofline\n",
    "    ai = np.logspace(-1, 3, 100)  # Arithmetic intensity from 0.1 to 1000\n",
    "    compute_roof = np.full_like(ai, peak_tflops)\n",
    "    memory_roof = ai * peak_bandwidth_gbs / 1000  # Convert GB/s to TB/s\n",
    "    \n",
    "    plt.plot(ai, np.minimum(compute_roof, memory_roof), 'k-', linewidth=2, label='Roofline')\n",
    "    plt.fill_between(ai, 0, np.minimum(compute_roof, memory_roof), alpha=0.1)\n",
    "    \n",
    "    # Plot operations\n",
    "    colors = plt.cm.Set1(np.linspace(0, 1, len(results)))\n",
    "    \n",
    "    for i, res in enumerate(results):\n",
    "        plt.scatter(res['arithmetic_intensity'], res['tflops'], \n",
    "                   color=colors[i], s=100, label=res['operation'], zorder=5)\n",
    "        \n",
    "        # Annotate\n",
    "        plt.annotate(res['operation'], \n",
    "                    (res['arithmetic_intensity'], res['tflops']),\n",
    "                    xytext=(5, 5), textcoords='offset points',\n",
    "                    fontsize=9)\n",
    "    \n",
    "    plt.xscale('log')\n",
    "    plt.yscale('log')\n",
    "    plt.xlabel('Arithmetic Intensity (FLOPs/byte)')\n",
    "    plt.ylabel('Performance (TFLOPS)')\n",
    "    plt.title(f'Roofline Model - {gpu.name}')\n",
    "    plt.grid(True, alpha=0.3)\n",
    "    plt.legend()\n",
    "    \n",
    "    # Add region labels\n",
    "    plt.text(0.5, peak_tflops * 0.8, 'Compute-bound', \n",
    "             ha='center', va='bottom', fontsize=10, fontweight='bold')\n",
    "    plt.text(100, peak_tflops * 0.1, 'Memory-bound', \n",
    "             ha='center', va='bottom', fontsize=10, fontweight='bold')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    print(\"\\nKey Insights:\")\n",
    "    print(\"1. Operations with high arithmetic intensity are compute-bound\")\n",
    "    print(\"2. Operations with low arithmetic intensity are memory-bound\")\n",
    "    print(\"3. Transformers have mixed behavior:\")\n",
    "    print(\"   - Attention: Low AI → memory-bound\")\n",
    "    print(\"   - Linear layers: High AI → compute-bound\")\n",
    "    print(\"4. Optimize based on bound type:\")\n",
    "    print(\"   - Memory-bound: Reduce data movement, improve access patterns\")\n",
    "    print(\"   - Compute-bound: Increase parallelism, use tensor cores\")\n",
    "    \n",
    "    return results"
   ]
  },
