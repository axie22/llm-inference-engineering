   "source": [
    "## 1.3 Manual Profiling - Understanding What Profiler Measures"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def manual_profiling_experiment():\n",
    "    \"\"\"Manual profiling to understand what each component costs.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "print(\"Manual Profiling - Component Breakdown\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "model.eval()\n",
    "\n",
    "x = torch.randn(1, 512, 512, device='cuda')\n",
    "\n",
    "# Warmup\n",
    "with torch.no_grad():\n",
    "    for _ in range(10):\n",
    "        _ = model(x)\n",
    "\n",
    "# Manual timing of components\n",
    "print(\"\\nTiming individual components (100 iterations each):\")\n",
    "\n",
    "components = {}\n",
    "\n",
    "# 1. Q/K/V projections\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        Q = model.q_proj(x)\n",
    "        K = model.k_proj(x)\n",
    "        V = model.v_proj(x)\n",
    "torch.cuda.synchronize()\n",
    "components['qkv_projections'] = (time.time() - start) / 100 * 1000\n",
    "\n",
    "# 2. Attention computation\n",
    "Q = model.q_proj(x)\n",
    "K = model.k_proj(x)\n",
    "V = model.v_proj(x)\n",
    "\n",
    "batch_size, seq_len, _ = x.shape\n",
    "Q_reshaped = Q.view(batch_size, seq_len, model.num_heads, model.head_dim).transpose(1, 2)\n",
    "K_reshaped = K.view(batch_size, seq_len, model.num_heads, model.head_dim).transpose(1, 2)\n",
    "V_reshaped = V.view(batch_size, seq_len, model.num_heads, model.head_dim).transpose(1, 2)\n",
    "\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        scores = torch.matmul(Q_reshaped, K_reshaped.transpose(-2, -1))\n",
    "        scores = scores / (model.head_dim ** 0.5)\n",
    "        weights = F.softmax(scores, dim=-1)\n",
    "        context = torch.matmul(weights, V_reshaped)\n",
    "torch.cuda.synchronize()\n",
    "components['attention_compute'] = (time.time() - start) / 100 * 1000\n",
    "\n",
    "# 3. Output projection\n",
    "context_flat = context.transpose(1, 2).contiguous().view(batch_size, seq_len, model.d_model)\n",
    "\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        _ = model.out_proj(context_flat)\n",
    "torch.cuda.synchronize()\n",
    "components['output_projection'] = (time.time() - start) / 100 * 1000\n",
    "\n",
    "# 4. FFN layers\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        _ = model.fc2(F.gelu(model.fc1(x)))\n",
    "torch.cuda.synchronize()\n",
    "components['ffn'] = (time.time() - start) / 100 * 1000\n",
    "\n",
    "# 5. Layer norms\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        _ = model.norm1(x)\n",
    "        _ = model.norm2(x)\n",
    "torch.cuda.synchronize()\n",
    "components['layer_norms'] = (time.time() - start) / 100 * 1000\n",
    "\n",
    "# Print results\n",
    "print(\"\\nComponent Timing Breakdown:\")\n",
    "print(\"-\" * 50)\n",
    "\n",
    "total_ms = sum(components.values())\n",
    "for name, ms in components.items():\n",
    "    percentage = ms / total_ms * 100\n",
    "    print(f\"  {name:20s}: {ms:6.2f} ms ({percentage:5.1f}%)\")\n",
    "\n",
    "print(\"-\" * 50)\n",
    "print(f\"  {'Total':20s}: {total_ms:6.2f} ms (100.0%)\")\n",
    "\n",
    "# Compare with full forward pass\n",
    "torch.cuda.synchronize()\n",
    "start = time.time()\n",
    "with torch.no_grad():\n",
    "    for _ in range(100):\n",
    "        _ = model(x)\n",
    "torch.cuda.synchronize()\n",
    "full_ms = (time.time() - start) / 100 * 1000\n",
    "\n",
    "print(f\"\\nFull forward pass: {full_ms:.2f} ms\")\n",
    "print(f\"Sum of components: {total_ms:.2f} ms\")\n",
    "print(f\"Difference: {full_ms - total_ms:.2f} ms ({abs(full_ms - total_ms)/full_ms*100:.1f}%)\")\n",
    "\n",
    "print(\"\\nNote: Difference accounts for overhead, memory transfers, etc.\")\n",
    "\n",
    "return components"
   ]
