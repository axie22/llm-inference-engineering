    "def production_profiling():\n",
    "    \"\"\"Advanced profiling techniques for production systems.\"\"\"\n",
    "    \n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Production Profiling\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    # 1. Multi-batch profiling\n",
    "    print(\"\\n1. Multi-Batch Profiling:\")\n",
    "    \n",
    "    batch_sizes = [1, 2, 4, 8, 16]\n",
    "    batch_results = []\n",
    "    \n",
    "    for bs in batch_sizes:\n",
    "        model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "        model.eval()\n",
    "        \n",
    "        x = torch.randn(bs, 512, 512, device='cuda')\n",
    "        \n",
    "        # Warmup\n",
    "        with torch.no_grad():\n",
    "            for _ in range(5):\n",
    "                _ = model(x)\n",
    "        \n",
    "        # Time\n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 50 // max(bs, 1)  # Adjust for total work\n",
    "        with torch.no_grad():\n",
    "            for _ in range(iterations):\n",
    "                _ = model(x)\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        # Calculate metrics\n",
    "        total_tokens = bs * 512 * iterations\n",
    "        tokens_per_sec = total_tokens / elapsed\n",
    "        avg_ms = elapsed / iterations * 1000\n",
    "        \n",
    "        # Memory\n",
    "        torch.cuda.reset_peak_memory_stats()\n",
    "        with torch.no_grad():\n",
    "            _ = model(x)\n",
    "        \n",
    "        peak_mb = torch.cuda.max_memory_allocated() / 1024**2\n",
    "        \n",
    "        batch_results.append({\n",
    "            'batch_size': bs,\n",
    "            'latency_ms': avg_ms,\n",
    "            'tokens_per_sec': tokens_per_sec,\n",
    "            'peak_memory_mb': peak_mb,\n",
    "            'memory_per_token_mb': peak_mb / (bs * 512)\n",
    "        })\n",
    "        \n",
    "        print(f\"  Batch {bs:2d}: {avg_ms:6.1f} ms, {tokens_per_sec:8.0f} tokens/sec, \"\n",
    "              f\"{peak_mb:6.1f} MB ({peak_mb/(bs*512):6.3f} MB/token)\")\n",
    "    \n",
    "    # Find optimal batch size\n",
    "    optimal = max(batch_results, key=lambda x: x['tokens_per_sec'])\n",
    "    print(f\"\\n  Optimal batch size: {optimal['batch_size']} \"\n",
    "          f\"({optimal['tokens_per_sec']:.0f} tokens/sec)\")\n",
    "    \n",
    "    # 2. Mixed precision profiling\n",
    "    print(\"\\n2. Mixed Precision Profiling:\")\n",
    "    \n",
    "    model_fp32 = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    model_fp16 = SimpleTransformerLayer(d_model=512, num_heads=8).cuda().half()\n",
    "    \n",
    "    x_fp32 = torch.randn(1, 512, 512, device='cuda')\n",
    "    x_fp16 = x_fp32.half()\n",
    "    \n",
    "    # Time FP32\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for _ in range(100):\n",
    "            _ = model_fp32(x_fp32)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    fp32_time = time.time() - start\n",
    "    \n",
    "    # Time FP16\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for _ in range(100):\n",
    "            _ = model_fp16(x_fp16)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    fp16_time = time.time() - start\n",
    "    \n",
    "    speedup = fp32_time / fp16_time\n",
    "    \n",
    "    print(f\"  FP32: {fp32_time:.3f}s ({100/fp32_time:.1f} iter/sec)\")\n",
    "    print(f\"  FP16: {fp16_time:.3f}s ({100/fp16_time:.1f} iter/sec)\")\n",
    "    print(f\"  Speedup: {speedup:.2f}x\")\n",
    "    \n",
    "    # 3. Concurrent profiling\n",
    "    print(\"\\n3. Concurrent Execution Profiling:\")\n",
    "    \n",
    "    # Test with CUDA streams\n",
    "    stream1 = torch.cuda.Stream()\n",
    "    stream2 = torch.cuda.Stream()\n",
    "    \n",
    "    model1 = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    model2 = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "    \n",
    "    x1 = torch.randn(1, 512, 512, device='cuda')\n",
    "    x2 = torch.randn(1, 512, 512, device='cuda')\n",
    "    \n",
    "    # Sequential\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for _ in range(50):\n",
    "            _ = model1(x1)\n",
    "            _ = model2(x2)\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    sequential_time = time.time() - start\n",
    "    \n",
    "    # Concurrent with streams\n",
    "    torch.cuda.synchronize()\n",
    "    start = time.time()\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for _ in range(50):\n",
    "            with torch.cuda.stream(stream1):\n",
    "                _ = model1(x1)\n",
    "            with torch.cuda.stream(stream2):\n",
    "                _ = model2(x2)\n",
    "            torch.cuda.synchronize()\n",
    "    \n",
    "    torch.cuda.synchronize()\n",
    "    concurrent_time = time.time() - start\n",
    "    \n",
    "    print(f\"  Sequential: {sequential_time:.3f}s\")\n",
    "    print(f\"  Concurrent: {concurrent_time:.3f}s\")\n",
    "    print(f\"  Improvement: {sequential_time/concurrent_time:.2f}x\")\n",
    "    \n",
    "    # 4. Energy profiling (if available)\n",
    "    print(\"\\n4. Energy Efficiency:\")\n",
    "    \n",
    "    try:\n",
    "        import pynvml\n",
    "        pynvml.nvmlInit()\n",
    "        handle = pynvml.nvmlDeviceGetHandleByIndex(0)\n",
    "        \n",
    "        # Get power usage\n",
    "        power_start = pynvml.nvmlDeviceGetPowerUsage(handle) / 1000  # Watts\n",
    "        \n",
    "        # Run workload\n",
    "        model = SimpleTransformerLayer(d_model=512, num_heads=8).cuda()\n",
    "        x = torch.randn(1, 512, 512, device='cuda')\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        start = time.time()\n",
    "        \n",
    "        iterations = 100\n",
    "        with torch.no_grad():\n",
    "            for _ in range(iterations):\n",
    "                _ = model(x)\n",
    "        \n",
    "        torch.cuda.synchronize()\n",
    "        elapsed = time.time() - start\n",
    "        \n",
    "        power_end = pynvml.nvmlDeviceGetPowerUsage(handle) / 1000  # Watts\n",
    "        \n",
    "        avg_power = (power_start + power_end) / 2\n",
    "        energy_joules = avg_power * elapsed\n",
    "        tokens_per_joule = (1 * 512 * iterations) / energy_joules\n",
    "        \n",
    "        print(f\"  Average power: {avg_power:.1f} W\")\n",
    "        print(f\"  Energy per inference: {energy_joules/iterations*1000:.1f} mJ\")\n",
    "        print(f\"  Tokens per joule: {tokens_per_joule:.0f}\")\n",
    "        \n",
    "        pynvml.nvmlShutdown()\n",
    "        \n",
    "    except ImportError:\n",
    "        print(\"  pynvml not available - install with 'pip install nvidia-ml-py3'\")\n",
    "    \n",
    "    # Summary\n",
    "    print(\"\\n\" + \"=\" * 70)\n",
    "    print(\"Production Profiling Summary\")\n",
    "    print(\"=\" * 70)\n",
    "    \n",
    "    print(\"\\nKey Production Insights:\")\n",
    "    print(\"1. Batch size optimization critical for throughput\")\n",
    "    print(\"2. Mixed precision provides significant speedup\")\n",
    "    print(\"3. Concurrent execution improves GPU utilization\")\n",
    "    print(\"4. Energy efficiency matters for cost and sustainability\")\n",
    "    print(\"5. Monitor power usage for thermal management\")\n",
    "    \n",
    "    return {\n",
    "        'batch_results': batch_results,\n",
    "        'fp16_speedup': speedup,\n",
    "        'concurrent_improvement': sequential_time / concurrent_time\n",
    "    }"
   ]
